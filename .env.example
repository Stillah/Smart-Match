# ── Ports ─────────────────────────────────────────────────────────────────────
COMPOSE_PROJECT_NAME=smartmatch

SMARTMATCH_FRONTEND_PORT=9999
SMARTMATCH_OCR_API_PORT=8000
SMARTMATCH_TRAINING_API_PORT=8100

# ── Volume mounts (host → container) ──────────────────────────────────────────
# Directory that contains classifier.pth and (optionally) trocr/ subdirectories.
SMARTMATCH_MODELS_HOST_DIR=./models
SMARTMATCH_MODELS_CONTAINER_DIR=/workspace/models

# Temporary runtime storage (OCR runs, training jobs, logs). Created automatically.
SMARTMATCH_RUNTIME_HOST_DIR=./.runtime
SMARTMATCH_RUNTIME_CONTAINER_DIR=/workspace/.runtime

# Image–text pair dataset used for TrOCR fine-tuning.
# Must contain images/ and texts/ subdirectories.
# Leave as default if you do not have a dataset yet — TrOCR training will be
# unavailable but OCR inference will still work.
SMARTMATCH_JOINED_DATA_HOST_DIR=./OCR/joined_data
SMARTMATCH_JOINED_DATA_CONTAINER_DIR=/workspace/OCR/joined_data

# Dataset directory for handwritten/typed classifier training.
# Leave as default if you do not have a dataset yet.
SMARTMATCH_TRAINING_DATA_HOST_DIR=./data
SMARTMATCH_TRAINING_DATA_CONTAINER_DIR=/workspace/data

# ── Runtime paths (inside container) ──────────────────────────────────────────
SMARTMATCH_RUNTIME_DIR=/workspace/.runtime
SMARTMATCH_JOINED_DATA_DIR=/workspace/OCR/joined_data

# ── Handwritten/Typed Classifier ──────────────────────────────────────────────
# Optional: override dataset directory used for classifier training.
SMARTMATCH_CLASSIFIER_DATASET_DIR=

# Path to the trained classifier weights inside the container.
SMARTMATCH_CLASSIFIER_WEIGHTS=/workspace/models/classifier.pth

SMARTMATCH_CLASSIFIER_TARGET_HEIGHT=64
SMARTMATCH_CLASSIFIER_TARGET_WIDTH=256
SMARTMATCH_CLASSIFIER_THRESHOLD=0.5
SMARTMATCH_CLASSIFIER_BATCH_SIZE=32

# ── Handwritten OCR — local fine-tuned TrOCR weights ─────────────────────────
# [OPTIONAL] Colon-separated paths to locally fine-tuned TrOCR model directories
# inside the container. Each directory name becomes a model key.
# Leave empty to rely solely on the Hugging Face base models below.
# Example: /workspace/models/trocr/kazars:/workspace/models/trocr/cyrillic
SMARTMATCH_TROCR_MODELS=

# Which model to use by default. Must match one of the model keys above,
# one of the base model names below, or "best" to auto-select per image.
SMARTMATCH_DEFAULT_HANDWRITTEN_MODEL=best

SMARTMATCH_OCR_HANDWRITTEN_LABEL=1

# ── Handwritten OCR — Hugging Face base models [REQUIRED] ─────────────────────
# Set these to valid Hugging Face model IDs before starting the stack.
# These are used when no locally fine-tuned weights are available.
# The container must have internet access on first start to download the models.
#
# Example values:
#   SMARTMATCH_TROCR_BASE_MODEL_KAZARS=kazars24/trocr-base-handwritten-ru
#   SMARTMATCH_TROCR_BASE_MODEL_CYRILLIC=cyrillic-trocr/trocr-handwritten-cyrillic
SMARTMATCH_TROCR_BASE_MODEL_KAZARS=
SMARTMATCH_TROCR_BASE_PROCESSOR_KAZARS=
SMARTMATCH_TROCR_BASE_MODEL_CYRILLIC=
SMARTMATCH_TROCR_BASE_PROCESSOR_CYRILLIC=

# ── TrOCR generation hyperparameters ──────────────────────────────────────────
SMARTMATCH_TROCR_NUM_BEAMS=8
SMARTMATCH_TROCR_MAX_NEW_TOKENS=128
SMARTMATCH_TROCR_LENGTH_PENALTY=0.8
SMARTMATCH_TROCR_NO_REPEAT_NGRAM_SIZE=3

# ── Printed OCR — PaddleOCR model names ───────────────────────────────────────
SMARTMATCH_PRINTED_TEXT_DETECTION_MODEL_NAME=PP-OCRv5_server_det
SMARTMATCH_PRINTED_TEXT_RECOGNITION_MODEL_NAME=eslav_PP-OCRv5_mobile_rec
SMARTMATCH_PRINTED_DOC_ORIENTATION_MODEL_NAME=PP-LCNet_x1_0_doc_ori
SMARTMATCH_PRINTED_DOC_UNWARPING_MODEL_NAME=UVDoc
SMARTMATCH_PRINTED_TEXTLINE_ORIENTATION_MODEL_NAME=PP-LCNet_x0_25_textline_ori

# ── Allowed input formats ──────────────────────────────────────────────────────
SMARTMATCH_ALLOWED_IMAGE_EXTENSIONS=.jpg,.jpeg,.png,.tif,.tiff,.bmp,.webp

# ── Confidence thresholds ──────────────────────────────────────────────────────
SMARTMATCH_LOW_CONFIDENCE_THRESHOLD=60
SMARTMATCH_HUMAN_REVIEW_THRESHOLD=60

# ── Default training hyperparameters — TrOCR ──────────────────────────────────
SMARTMATCH_TRAINING_DEFAULT_TROCR_EPOCHS=10
SMARTMATCH_TRAINING_DEFAULT_TROCR_BATCH_SIZE=8
SMARTMATCH_TRAINING_DEFAULT_TROCR_LEARNING_RATE=0.00003
SMARTMATCH_TRAINING_DEFAULT_TROCR_NUM_SAMPLES=
SMARTMATCH_TRAINING_DEFAULT_TROCR_TRAIN_SPLIT=0.9
SMARTMATCH_TRAINING_DEFAULT_TROCR_SEED=42
SMARTMATCH_TRAINING_DEFAULT_TROCR_MAX_TARGET_LENGTH=128
SMARTMATCH_TRAINING_DEFAULT_TROCR_WARMUP_STEPS=100
SMARTMATCH_TRAINING_DEFAULT_TROCR_LOGGING_STEPS=50
SMARTMATCH_TRAINING_DEFAULT_TROCR_SAVE_TOTAL_LIMIT=2

# ── Default training hyperparameters — Classifier ─────────────────────────────
SMARTMATCH_TRAINING_DEFAULT_CLASSIFIER_BATCH_SIZE=32
SMARTMATCH_TRAINING_DEFAULT_CLASSIFIER_NUM_EPOCHS=10
SMARTMATCH_TRAINING_DEFAULT_CLASSIFIER_LEARNING_RATE=0.001
SMARTMATCH_TRAINING_DEFAULT_CLASSIFIER_PATIENCE=5
SMARTMATCH_TRAINING_DEFAULT_CLASSIFIER_RANDOM_STATE=42
SMARTMATCH_TRAINING_DEFAULT_CLASSIFIER_TARGET_HEIGHT=64
SMARTMATCH_TRAINING_DEFAULT_CLASSIFIER_TARGET_WIDTH=256
SMARTMATCH_TRAINING_DEFAULT_CLASSIFIER_TEST_SPLIT=0.3
SMARTMATCH_TRAINING_DEFAULT_CLASSIFIER_VAL_SPLIT=0.5

# ── Internal service URLs (used by the nginx frontend proxy) ───────────────────
SMARTMATCH_OCR_API_UPSTREAM=http://smartmatch-ocr:8000
SMARTMATCH_TRAINING_API_UPSTREAM=http://smartmatch-training:8100
